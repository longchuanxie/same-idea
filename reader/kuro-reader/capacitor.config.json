{
  "appId": "com.kuro.reader",
  "appName": "Kuro Reader",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#fdf8f8",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#fdf8f8"
    },
    "Keyboard": {
      "resize": "body"
    }
  }
}
